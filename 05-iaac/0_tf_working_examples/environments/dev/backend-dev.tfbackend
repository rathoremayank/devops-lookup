skip_credentials_validation = false
skip_metadata_api_check     = false

# These values will be provided via -backend-config during terraform init
# Or you can set them directly here after running setup-remote-state.sh

# S3 bucket for storing Terraform state
bucket = "terraform-state-1774433916"

# Path within the bucket
key = "k8s-cluster/dev/terraform.tfstate"

# AWS region
region = "us-east-1"

# Enable encryption
encrypt = true

# Note: DynamoDB is no longer used - S3 versioning provides state management
